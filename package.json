{
  "name": "tinyide",
  "version": "0.1.0",
  "description": "IDE extensível baseada em navegador, empacotada para Linux.",
  "main": "apps/desktop/main.cjs",
  "author": "tinyIde",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --config apps/web/vite.config.mjs apps/web",
    "start": "npm run dev",
    "start:desktop": "electron --ozone-platform=x11 .",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace @tinyide/web",
    "prepare:plugins": "npm ci --prefix plugins/terminal",
    "build:plugins": "npm run prepare:plugins && npm run build --prefix plugins/git && npm run build --prefix plugins/terminal",
    "build:desktop": "npm run build:web && npm run build:plugins",
    "build:deb": "npm run build:desktop && electron-builder --linux deb --x64 --publish never",
    "preview": "vite preview --config apps/web/vite.config.mjs apps/web",
    "test": "vitest run packages apps/web/src apps/desktop --exclude '**/*.performance.test.ts'",
    "test:performance": "vitest run apps/web/src/file-browser.performance.test.ts && npm run test:performance --prefix plugins/python-venv",
    "coverage:core": "vitest run packages --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.include='packages/core/src/**/*.ts' --coverage.exclude='packages/core/src/**/*.test.ts' --coverage.exclude='packages/core/src/index.ts' --coverage.thresholds.lines=100 --coverage.thresholds.functions=100 --coverage.thresholds.statements=100 --coverage.thresholds.branches=100",
    "coverage:web-critical": "vitest run apps/web/src/file-browser.test.ts apps/web/src/browser-filesystem.test.ts apps/web/src/app/workspace-settings.test.ts --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.include='apps/web/src/file-browser.ts' --coverage.include='apps/web/src/browser-filesystem.ts' --coverage.include='apps/web/src/app/workspace-settings.ts' --coverage.thresholds.lines=100 --coverage.thresholds.functions=100 --coverage.thresholds.statements=100 --coverage.thresholds.branches=100",
    "coverage:runtime-security": "vitest run apps/desktop/security.test.mjs apps/desktop/startup.test.mjs packages/runtime-server/src/index.test.mjs --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.include='apps/desktop/security.cjs' --coverage.include='apps/desktop/startup.cjs' --coverage.include='packages/runtime-server/src/index.mjs' --coverage.thresholds.lines=75 --coverage.thresholds.functions=85 --coverage.thresholds.statements=70 --coverage.thresholds.branches=60",
    "coverage:plugins": "npm run coverage --prefix plugins/python && npm run coverage --prefix plugins/python-venv",
    "coverage": "npm run coverage:core && npm run coverage:web-critical && npm run coverage:runtime-security && npm run coverage:plugins",
    "typecheck:plugins": "tsc -p plugins/python/jsconfig.json && tsc -p plugins/python-venv/jsconfig.json && tsc -p plugins/terminal/jsconfig.json && tsc -p plugins/git/jsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && npm run typecheck:plugins",
    "check": "npm run typecheck && npm run test && npm run test:performance && npm run coverage && npm run build"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "build": {
    "appId": "dev.tinyide.desktop",
    "productName": "tinyIde",
    "artifactName": "tinyide_${version}_${arch}.${ext}",
    "asar": false,
    "npmRebuild": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "apps/desktop/**/*",
      "!apps/desktop/**/*.test.*",
      "apps/web/dist/**/*",
      "packages/runtime-server/**/*",
      "!packages/runtime-server/**/*.test.*",
      "plugins/*/plugin.json",
      "plugins/*/dist/**/*",
      "plugins/*/src/index.js",
      "plugins/*/src/backend.mjs",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "executableName": "tinyide",
      "executableArgs": [
        "--ozone-platform=x11"
      ],
      "icon": "build/icon.png",
      "maintainer": "tinyIde"
    },
    "deb": {
      "priority": "optional",
      "afterInstall": "build/after-install.sh",
      "afterRemove": "build/after-remove.sh"
    }
  }
}
