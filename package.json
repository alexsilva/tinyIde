{
  "name": "tinyide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --config apps/web/vite.config.mjs apps/web",
    "start": "npm run dev",
    "build": "npm run build --workspaces --if-present",
    "preview": "vite preview --config apps/web/vite.config.mjs apps/web",
    "test": "vitest run packages",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
